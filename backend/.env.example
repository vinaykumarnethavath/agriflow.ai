# Database (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agrichain

# Frontend URL for CORS (REQUIRED in production)
# For local development, leave empty
# For production: https://your-frontend-url.vercel.app
FRONTEND_URL=

# JWT Secret (REQUIRED in production - use a strong random string)
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=your-secure-jwt-secret-here

# Razorpay (if using payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Groq AI (for RAG chatbot)
GROQ_API_KEY=your_groq_api_key

# Email (for email OTP features)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Fast2SMS (for phone OTP)
FAST2SMS_API_KEY=your_fast2sms_api_key

# OpenCage Geocoding API (for location features)
# Get free key at: https://opencagedata.com/api
OPENCAGE_API_KEY=your_opencage_api_key

# News API (for agricultural news)
# Get free key at: https://newsapi.org/
NEWS_API_KEY=your_news_api_key

# OpenWeatherMap API (for real-time weather)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key
